data/processed/

# ── Model files (too large for git) ───────────────────────────────────────────
results/models/*.h5
results/models/*.pkl

# ── NumPy prediction arrays (too large, regenerate by running pipeline) ───────
results/metrics/*.npy

# ── Keep these result files ───────────────────────────────────────────────────
!results/metrics/all_results.csv
!results/metrics/lstm_history.csv

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

